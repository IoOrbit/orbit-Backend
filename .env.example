# Server Configuration
PORT=3000
RUST_LOG=debug

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/orbit
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret
APPLE_REDIRECT_URI=http://localhost:3000/auth/apple/callback

# HSM Configuration (for production)
HSM_ENDPOINT=https://your-hsm-service.com
HSM_API_KEY=your-hsm-api-key
HSM_KEY_ID=key-1

# Reward Pool Configuration
REWARD_POOL_WALLET_SECRET=your-reward-pool-secret
REWARD_POOL_PUBLIC_KEY=your-reward-pool-public-key

# External Services
MIXPANEL_TOKEN=your-mixpANEL-token
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:19006
